  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 4
  indentLevel: 0
  storyText: '[She slams both of her hands onto Clara''s desk]'
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
