--- !u!114 &1560875325
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1560875300}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 24
  indentLevel: 0
  storyText: But then Clara had to play the hero. She took everything from me. My
    grades, my parents' pride, my entire future... all gone in an instant.
  description: 
  character: {fileID: 432612737}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
  waitForClick: 1
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &1560875326
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1560875300}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 23
  indentLevel: 0
  storyText: I couldn't fail that exam. My parents would have disowned me... I just
    needed to pass. I had to cheat just to survive in my own home.
  description: 
  character: {fileID: 432612737}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
